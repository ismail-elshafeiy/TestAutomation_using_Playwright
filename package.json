{
    "name": "testautomation_playwright",
    "version": "1.0.0",
    "description": "Playwright Framework with Typescript",
    "private": true,
    "main": "index.js",
    "author": "Ismail Elshafeiy",
    "license": "ISC",
    "keywords": [
        "playwright",
        "typescript",
        "test-automation",
        "e2e",
        "allure"
    ],
    "scripts": {
        "inspector": "playwright codegen playwright.dev",
        "stg": "npx cross-env ENV=stg",
        "prod": "npx cross-env ENV=prod",
        "test": "playwright test",
        "test:headed": "playwright test --headed",
        "test:ui": "playwright test --ui",
        "test:chrome": "playwright test --project='Chrome - UI'",
        "test:stg": "npx cross-env ENV=stg playwright test",
        "test:prod": "npx cross-env ENV=prod playwright test",
        "test:login": "playwright test Login.test.ts --project='Chrome - UI'",
        "test:smoke": "playwright test --grep @Smoke --workers=1 --project='Chrome - UI'",
        "test:api": "playwright test --grep @API --workers=1 --project='Chrome - UI'",
        "clean": "rimraf reports/allure-results allure-results reports/playwright-report allure-report test-results",
        "typecheck": "tsc --noEmit",
        "pw:install": "playwright install --with-deps",
        "allure:report": "allure serve reports/allure-results",
        "allure:generate": "allure generate reports/allure-results --output allure-report --clean",
        "allure:open": "allure open allure-report",
        "test:reporter": "npm run clean && playwright test --headed --reporter=allure-playwright,line",
        "lighthouse": "node tests/Lighthouse.js"
    },
    "dependencies": {
        "@applitools/eyes-playwright": "^1.47.8",
        "@types/adm-zip": "^0.5.8",
        "@types/crypto-js": "^4.2.2",
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "@typescript-eslint/parser": "^8.61.1",
        "adm-zip": "^0.5.17",
        "cross-env": "^10.1.0",
        "crypto-js": "^4.2.0",
        "csv-parse": "^7.0.0",
        "eslint": "^10.5.0",
        "eslint-plugin-import": "^2.32.0",
        "exceljs": "^4.4.0",
        "i": "^0.3.7",
        "lighthouse": "^13.4.0",
        "monocart-reporter": "^2.11.2",
        "npm": "^11.17.0",
        "pdfjs-dist-es5": "^2.13.216",
        "pg": "^8.21.0",
        "playwright-lighthouse": "^4.0.0",
        "punycode": "^2.3.1",
        "rimraf": "^6.1.3",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "@faker-js/faker": "^10.4.0",
        "@playwright/test": "^1.61.0",
        "@reportportal/agent-js-playwright": "^5.4.1",
        "@types/faker": "^6.6.11",
        "@types/node": "^25.9.3",
        "@wdio/cli": "^9.28.0",
        "allure-commandline": "^2.42.1",
        "allure-playwright": "^3.10.0",
        "prettier": "^3.8.4",
        "typescript": "^6.0.3"
    },
    "packageManager": "yarn@4.5.0"
}
